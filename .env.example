# Alpha Vault — environment variables
# ====================================
# Copy this file to `.env.local` for local development and fill in the values.
# In production, set the same variables in Netlify:
#   Site settings → Environment variables.

# --- Server-only (never sent to the browser; no NEXT_PUBLIC_ prefix) --------

# Supabase project URL, e.g. https://abcdefgh.supabase.co
# Find it in: Supabase Dashboard → Project Settings → Data API → Project URL
SUPABASE_URL=

# Supabase SERVICE ROLE key (secret). Bypasses Row Level Security. Powerful —
# treat it like a password and never commit a real value.
# Find it in: Supabase Dashboard → Project Settings → API Keys → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Discord webhook URL for the admin channel notification (Phase 1.5). Posts a
# card for every new application. Optional — if unset, the notification is
# silently skipped and the form still works normally.
# Create it in: Discord → your admin channel → Edit Channel → Integrations →
# Webhooks → New Webhook → Copy Webhook URL.
DISCORD_WEBHOOK_URL=

# --- Public (safe to expose — Next.js inlines these into the browser bundle) -

# Same Supabase project as SUPABASE_URL above — just repeated under a
# NEXT_PUBLIC_ name so the browser-side auth client (lib/supabase/client.ts)
# can read it. Same value either way, just needs the public-visible name too.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase's PUBLIC/anon key — NOT the service role key. This one is designed
# to be exposed to the browser; it only works within whatever Row Level
# Security policies are defined (see supabase/campaign_schema.sql). Used for
# the Campaign sign-up/sign-in modals.
# Find it in: Supabase Dashboard → Project Settings → API Keys → anon/public
# (or "Publishable key" on newer Supabase projects)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: only if you move to a custom domain. Controls the absolute URL used
# for social-share (OG) images. Defaults to the Netlify URL if unset.
# NEXT_PUBLIC_SITE_URL=https://your-custom-domain.com
