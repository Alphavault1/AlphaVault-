# Alpha Vault — environment variables
# ====================================
# Copy this file to `.env.local` for local development and fill in the values.
# In production, set the same variables in Netlify:
#   Site settings → Environment variables.
#
# Both are SERVER-ONLY (no NEXT_PUBLIC_ prefix), so they are never shipped to
# the browser. The service-role key is powerful — treat it like a password and
# never commit real values.

# Supabase project URL, e.g. https://abcdefgh.supabase.co
# Find it in: Supabase Dashboard → Project Settings → Data API → Project URL
SUPABASE_URL= https://cmrvlmkilskspmllqdgx.supabase.co

# Supabase SERVICE ROLE key (secret). Bypasses Row Level Security.
# Find it in: Supabase Dashboard → Project Settings → API Keys → service_role
SUPABASE_SERVICE_ROLE_KEY= sb_secret_rf7ufhcout6nI93sEkwbUg_wC0uHwG2

# Optional: only if you move to a custom domain. Controls the absolute URL used
# for social-share (OG) images. Defaults to the Netlify URL if unset.
# NEXT_PUBLIC_SITE_URL=https://your-custom-domain.com
